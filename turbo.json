{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HOST",
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "STUDYFRAME_LOG_WS_EVENTS",
    "STUDYFRAME_MODE",
    "STUDYFRAME_PORT",
    "STUDYFRAME_NO_BROWSER",
    "STUDYFRAME_HOME",
    "STUDYFRAME_AUTH_TOKEN",
    "STUDYFRAME_TAILSCALE_SERVE",
    "STUDYFRAME_TAILSCALE_SERVE_PORT",
    "STUDYFRAME_DESKTOP_WS_URL",
    "STUDYFRAME_TRACE_MIN_LEVEL",
    "STUDYFRAME_TRACE_TIMING_ENABLED",
    "STUDYFRAME_TRACE_FILE",
    "STUDYFRAME_TRACE_MAX_BYTES",
    "STUDYFRAME_TRACE_MAX_FILES",
    "STUDYFRAME_TRACE_BATCH_WINDOW_MS",
    "STUDYFRAME_OTLP_TRACES_URL",
    "STUDYFRAME_OTLP_METRICS_URL",
    "STUDYFRAME_OTLP_EXPORT_INTERVAL_MS",
    "STUDYFRAME_OTLP_SERVICE_NAME",
    "APP_VERSION",
    "VITE_HOSTED_APP_URL",
    "VITE_HOSTED_APP_CHANNEL"
  ],
  "globalPassThroughEnv": ["PATHEXT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "dependsOn": ["@t3tools/contracts#build"],
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
